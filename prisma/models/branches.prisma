model Branch {
    id           String         @id @default(uuid())
    name         String
    address      String?
    city         String?
    state        String?
    zip          String?
    country      String?
    phone        String?
    email        String?        @unique
    users        User[]
    invites      Invites[]
    products      Product[]
    activityLogs ActivityLogs[]
    isDeleted    Boolean        @default(false)
    deletedAt    DateTime?
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
}
